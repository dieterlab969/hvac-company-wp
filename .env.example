# WordPress Database Configuration
# ================================
# This project uses SQLite as the database backend by default.
# The DB_ENGINE is set to 'sqlite' in wp-config.php.
#
# If you want to switch to MySQL/MariaDB, update DB_ENGINE and these settings:
DB_NAME=phangia_d
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_CHARSET=utf8mb4
DB_COLLATE=

# WordPress Security Keys & Salts
# Generate new keys at: https://api.wordpress.org/secret-key/1.1/salt/
AUTH_KEY='your-unique-auth-key'
SECURE_AUTH_KEY='your-unique-secure-auth-key'
LOGGED_IN_KEY='your-unique-logged-in-key'
NONCE_KEY='your-unique-nonce-key'
AUTH_SALT='your-unique-auth-salt'
SECURE_AUTH_SALT='your-unique-secure-auth-salt'
LOGGED_IN_SALT='your-unique-logged-in-salt'
NONCE_SALT='your-unique-nonce-salt'

# Debug Mode (set to true to enable WordPress debug logging)
WP_DEBUG=false

# Site Configuration
# The site URL is dynamically set from the request host in wp-config.php.
# Override here if you need a fixed URL:
# WP_HOME=https://yourdomain.com
# WP_SITEURL=https://yourdomain.com

# Plugin Settings
ZALO_URL=https://zalo.me/164848896161853582
